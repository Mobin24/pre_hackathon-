# Backend runtime
APP_ENV=development
APP_PORT=8000

# AI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# MongoDB Atlas (project: DRRCS, cluster: dsd-cluster)
MONGODB_URI=mongodb+srv://user:password@dsd-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=drrcs_dev

# CORS (comma-separated; frontend Vite default is http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# JWT / Auth
# Generate a strong secret for production: `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_MINUTES=1440

# Admin provisioning
# Public /auth/register hardcodes role=citizen. Use this token to call the
# internal POST /admin/seed endpoint (X-Admin-Secret header). Generate with
# `openssl rand -hex 32` and keep it out of the frontend repo.
# ADMIN_SEED_TOKEN=
